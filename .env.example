# copy this to .env.local and fill in the values
# .env.local is already in .gitignore so it won't get committed


# --- supabase (postgres) ------------------------------------------------------
# both urls come from: supabase dashboard → settings → database → connection string
# DATABASE_URL  uses port 6543 (transaction/pooler mode) — used at runtime
# DIRECT_URL    uses port 5432 (direct session mode)   — used by prisma db push

DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"


# --- supabase auth ------------------------------------------------------------
# from: supabase dashboard → settings → api

NEXT_PUBLIC_SUPABASE_URL="https://[your-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."  # never expose this one to the browser


# --- github oauth app ---------------------------------------------------------
# create one at: github.com/settings/developers → new oauth app
# callback url: https://[your-ref].supabase.co/auth/v1/callback

GITHUB_CLIENT_ID="Ov23..."
GITHUB_CLIENT_SECRET="..."

# optional — used as a fallback for unauthenticated github api calls
GITHUB_PAT="ghp_..."


# --- redis (upstash) ----------------------------------------------------------
# create a database at: console.upstash.com
# grab the ioredis url from: database → details → connect → ioredis

REDIS_URL="rediss://default:[password]@[host].upstash.io:6379"


# --- ai (llm) -----------------------------------------------------------------
# groq handles all llm tasks: issue classification, skill profiling, contribution summaries
# get your key at: console.groq.com → api keys → create key (free, no credit card)

GROQ_API_KEY="gsk_..."


# --- ai (embeddings) ----------------------------------------------------------
# hugging face handles vector embeddings — completely free, no credit card
# model: sentence-transformers/all-MiniLM-L6-v2 (384-dim vectors)
# get your token at: huggingface.co/settings/tokens → new token → read access is enough

HUGGINGFACE_TOKEN="hf_..."


# --- app ---------------------------------------------------------------------

NEXT_PUBLIC_APP_URL="http://localhost:3000"

# put this same string in your github repo webhook settings → secret field
GITHUB_WEBHOOK_SECRET="some-random-string"
