// parent record that ties a user to all their skills
// gets re-stamped with updatedAt every time the profiling agent reruns

model SkillProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  updatedAt DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills Skill[]

  @@map("skill_profiles")
}
