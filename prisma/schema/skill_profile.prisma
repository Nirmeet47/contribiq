// parent record that ties a user to all their skills
// gets re-stamped with updatedAt every time the profiling agent reruns
// vector embeddings live in skill_embeddings so normal SkillProfile queries stay typed

model SkillProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  totalCommits Int      @default(0)
  totalRepos   Int      @default(0)
  mergedPRs    Int      @default(0)
  updatedAt    DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills         Skill[]
  skillEmbedding SkillEmbedding?

  @@map("skill_profiles")
}

// Prisma can create this table, but reads/writes involving embedding must use
// prisma.$queryRaw / prisma.$executeRaw because pgvector is Unsupported.
model SkillEmbedding {
  skillProfileId String                     @id @map("skill_profile_id")
  embedding      Unsupported("vector(768)")
  updatedAt      DateTime                   @default(now()) @updatedAt @map("updated_at")

  skillProfile SkillProfile @relation(fields: [skillProfileId], references: [id], onDelete: Cascade)

  @@map("skill_embeddings")
}
