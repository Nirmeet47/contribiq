{
  "name": "contribiq",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "prisma generate",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "ai:worker": "python -m agent.scheduler",
    "repo:discover": "python -m agent.repo_discovery",
    "repo:docs": "python -m agent.repo_docs_ingestion",
    "issues:fetch": "python -m agent.issue_fetcher",
    "issues:classify": "python -m agent.issue_classifier",
    "matches:score": "python -m agent.match_scoring",
    "contributions:process": "python -m agent.contribution_summary",
    "ai:api": "uvicorn agent.api:app --host 0.0.0.0 --port 8001"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "@tailwindcss/typography": "^0.5.20",
    "@tanstack/react-query": "^5.101.1",
    "dotenv": "^17.4.2",
    "groq-sdk": "^1.3.0",
    "ioredis": "^5.11.1",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "pg": "^8.21.0",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
